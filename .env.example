# ── LinkedIn Developer App (OAuth 2.0) ──────────────────────────────────────
# Required for: creating posts, fetching profile
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_PORT=8080

# ── Your LinkedIn account (Voyager API) ─────────────────────────────────────
# Required for: reading posts, job search, connection outreach
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Anthropic API ────────────────────────────────────────────────────────────
# Required for: Module 2 (scheduler), Module 3 (outreach notes), Module 4 (job scoring)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Module 2: Scheduler ──────────────────────────────────────────────────────
# Time to publish daily (24h format, server local time)
SCHEDULE_TIME=09:00
# What Claude should write about
POST_TOPIC=share a professional insight about software engineering or career growth
# PUBLIC or CONNECTIONS
POST_VISIBILITY=PUBLIC

# ── Module 3: Connection Outreach ────────────────────────────────────────────
# Search keywords for target profiles
OUTREACH_KEYWORDS=Python engineer
# Network depth: S=2nd degree, O=3rd+ (comma-separated, e.g. S,O)
OUTREACH_NETWORK=S
# Max connection requests per calendar day (keep low to avoid LinkedIn flags)
OUTREACH_DAILY_LIMIT=5
# Brief description of yourself (used to personalise the connection note)
OUTREACH_YOUR_ROLE=software engineer
# Why you're connecting (used to personalise the connection note)
OUTREACH_REASON=explore collaboration opportunities

# ── Module 4: Job Scoring ────────────────────────────────────────────────────
# No extra config needed — uses ANTHROPIC_API_KEY + LINKEDIN_EMAIL/PASSWORD above.
# Add your CV / skills to profile.txt in the project root for richer scoring.
